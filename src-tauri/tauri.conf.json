{
  "productName": "D2MXLUtils",
  "version": "1.9.0",
  "identifier": "com.d2mxlutils.app",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "security": {
      "csp": null
    },
    "windows": [
      {
        "label": "main",
        "title": "D2MXLUtils",
        "width": 1040,
        "height": 740,
        "resizable": true,
        "fullscreen": false
      },
      {
        "label": "overlay",
        "title": "D2MXLUtils Overlay",
        "width": 800,
        "height": 600,
        "resizable": false,
        "fullscreen": false,
        "decorations": false,
        "transparent": true,
        "skipTaskbar": true,
        "alwaysOnTop": true,
        "visible": false
      }
    ]
  },
  "bundle": {},
  "plugins": {}
}



